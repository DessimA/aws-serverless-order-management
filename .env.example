# --- Deployment Target (aws | localstack) ---
DEPLOY_TARGET=localstack

# --- Caso queira testa no LocalStack ---
LOCALSTACK_AUTH_TOKEN=SUA_CHAVE_LOCAL_STACK

# --- Project Configuration ---
AWS_REGION=SUA-REGIAO
PROJECT_NAME=NOME-DO-PROJETO
RESOURCE_SUFFIX=SEU-NOME
NOTIFICATION_EMAIL=SEU-EMAIL

# --- (Opcional) IP permitido para chamadas ao endpoint /test ---
# ALLOWED_SOURCE_IP=x.x.x.x/x
# Se vazio, nenhuma restricao de IP e aplicada.

# --- Resource Names (Generated based on suffix) ---
# O script usará o RESOURCE_SUFFIX para garantir nomes únicos